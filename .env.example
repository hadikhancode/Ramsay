# port the app runs on
APP_PORT=5000

# allrecipes search link
BASE_URL=https://www.allrecipes.com/search
# how many results per search page (you shouldnt have to change this)
RESULTS_PER_PAGE=24
# how long to wait for search results before giving up
SEARCH_TIMEOUT_SECONDS=15
# how long to wait for recipe details before giving up
DETAIL_TIMEOUT_SECONDS=10

# default max_results when client doesn't send one
API_RESULTS_DEFAULT=10
# lowest allowed max_results value
API_MIN_RESULTS=1
# highest allowed max_results value
API_MAX_RESULTS=50

# google cloud console project id with Vertex AI API enabled
GOOGLE_CLOUD_CONSOLE_PROJECT_ID=your-google-cloud-console-project-id
# gemini model, 2.5 is default because it allows using the specific regions (to avoid 429 errors)
GEMINI_MODEL=gemini-2.5-flash
# max number of async workers for gemini
GEMINI_MAX_WORKERS=10
# locations for gemini region rotation (to avoid 429 errors)
GEMINI_LOCATIONS=us-central1,us-east4,us-east1,us-west1,us-west4,us-south1,us-east5,northamerica-northeast1,southamerica-east1,europe-west1,europe-west4,europe-west2,europe-west3,europe-west9,europe-north1,europe-southwest1,europe-central2,asia-northeast1,asia-northeast3,asia-southeast1,asia-south1,australia-southeast1
# how many rounds of region rotation before giving up (0 for infinite)
GEMINI_REGION_ROTATION_MAX_ROUNDS=0
# how many seconds to wait between region rotation attempts if gemini returns a 429 error
GEMINI_REGION_ROTATION_DELAY_SECONDS=3

# how many seconds to wait before retrying a request that returned a 429 error due to quota limits
QUOTA_RETRY_DELAY_SECONDS=3
# full-request retries after region swapping gives up (429 error)
QUOTA_RETRY_ATTEMPTS=2

# default user agent for HTTP requests to allrecipes
HTTP_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36
# default accept language for HTTP requests to allrecipes
HTTP_ACCEPT_LANGUAGE=en-US,en;q=0.9

# featherless api key
FEATHERLESS_API_KEY=your-featherless-api-key
# featherless chat endpoint
FEATHERLESS_CHAT_URL=https://api.featherless.ai/v1/chat/completions
# featherless chat bot model
FEATHERLESS_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct
# how long to wait for featherless chat response before giving up
FEATHERLESS_TIMEOUT_SECONDS=45
# temperature for featherless chat responses (0.0-1.0, higher is more creative)
FEATHERLESS_TEMPERATURE=0.7
# persona for the ramsay chat bot
RAMSAY_PERSONA=You are Gordon Ramsay in MasterChef Junior mode. You are high-energy, encouraging, and use British slang like 'spot on' and 'stunning'. You never insult the user and always give constructive cooking advice. Always refer to the user as 'Chef'.